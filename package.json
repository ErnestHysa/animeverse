{
  "name": "anime-stream-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:next": "node scripts/start-next-webpack.mjs",
    "build": "tsc --noEmit -p tsconfig.build.json && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:e2e",
    "electron:dev": "tsc -p electron/tsconfig.json && electron .",
    "electron:build": "tsc -p electron/tsconfig.json && electron-builder",
    "electron:pack": "tsc -p electron/tsconfig.json && electron-builder --dir",
    "tracker:start": "ts-node services/anime-tracker.ts",
    "tracker:dev": "nodemon --exec ts-node services/anime-tracker.ts"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@types/cheerio": "^0.22.35",
    "@types/ws": "^8.18.1",
    "archiver": "^7.0.1",
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dashjs": "^5.1.1",
    "framer-motion": "^12.38.0",
    "graphql-request": "^7.4.0",
    "hls.js": "^1.6.15",
    "lucide-react": "^0.577.0",
    "magnet-uri": "^6.2.0",
    "next": "^16.2.1",
    "p2p-media-loader-core": "^2.2.2",
    "p2p-media-loader-hlsjs": "^2.2.2",
    "parse-torrent": "^9.1.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^3.5.0",
    "webtorrent": "^2.8.5",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/archiver": "^7.0.0",
    "@types/electron": "^1.4.38",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/webtorrent": "^0.109.10",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "happy-dom": "^20.8.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.animestream.desktop",
    "productName": "Anime Stream",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.entertainment"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "icon": "assets/icon.png",
      "category": "Video"
    }
  }
}
