# =====================================================
# AnimeVerse Environment Variables
# Copy this file to .env.local and fill in your values
# =====================================================

# ── AniList OAuth ──────────────────────────────────
# Register your app at https://anilist.co/settings/developer
NEXT_PUBLIC_ANILIST_CLIENT_ID=your_anilist_client_id
ANILIST_CLIENT_SECRET=your_anilist_client_secret

# ── MyAnimeList OAuth (optional) ──────────────────
# Register your app at https://myanimelist.net/apiconfig
NEXT_PUBLIC_MAL_CLIENT_ID=your_mal_client_id
MAL_CLIENT_SECRET=your_mal_client_secret  # optional for public clients using PKCE

# ── App URL ────────────────────────────────────────
# Full URL of your deployment (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── AniList API (optional override) ───────────────
# Defaults to https://graphql.anilist.co
ANILIST_GRAPHQL_URL=https://graphql.anilist.co

# ── Logging (optional) ────────────────────────────
# Set to "true" to enable verbose logging
NEXT_PUBLIC_ENABLE_LOGGING=false
# Log level: debug | info | warn | error
NEXT_PUBLIC_LOG_LEVEL=warn

# ── Authentication ─────────────────────────────────
# JWT Secret (required)
JWT_SECRET=your-jwt-secret-here

# Admin credentials (required)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme

# ── CORS ───────────────────────────────────────────
# Allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# ── Anime Tracker ──────────────────────────────────
ADMIN_KEY=your-admin-key
ANIME_TRACKER_PORT=8000
ANIME_TRACKER_WS_PORT=8001
TRACKER_PASSKEY=your-tracker-passkey

# ── Seed Server ────────────────────────────────────
SEED_CONTENT_PATH=./data/seeds
MAX_TORRENTS=100
STATUS_PORT=3002
